# Root-managed, shell-compatible deployment configuration.
GOAL_ROOT=/opt/goal
GOAL_REPOSITORY_URL=https://github.com/madcamp-official/26s-w2-c2-08.git
GITHUB_REPOSITORY=madcamp-official/26s-w2-c2-08
GITHUB_WORKFLOW_FILE=ci.yml
GITHUB_TOKEN_FILE=/etc/goal/secrets/github_deploy_token
GOAL_APP_ENV=/etc/goal/goal.env
GOAL_HEALTH_URL=http://127.0.0.1:8000/api/health/db

# Enable recording_transcription only after its production STT runtime is ready.
GOAL_SERVICES="goal-api.service goal-worker@material.service goal-worker@knowledge.service goal-worker@clustering.service goal-worker@personal_ai.service goal-worker@postprocessing.service goal-worker@lifecycle.service"
