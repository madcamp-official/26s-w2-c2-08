APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000

POSTGRES_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
POSTGRES_DB=tbd
POSTGRES_USER=tbd
POSTGRES_PASSWORD=tbd_dev

# Optional for development. APP_ENV=production requires an explicit URL that
# does not use the repository tbd/tbd_dev credentials.
# DATABASE_URL=postgresql+psycopg://tbd:tbd_dev@127.0.0.1:5432/tbd

STORAGE_ROOT=./data/uploads
# Decimal 100 MB. This must match the Material DB constraint and API contract.
MAX_UPLOAD_BYTES=100000000

# Browser authentication. Production requires HTTPS origins, a unique secret,
# Google credentials, and AUTH_COOKIE_SECURE=true.
FRONTEND_ORIGIN=http://localhost:5173
AUTH_ALLOWED_ORIGINS=http://localhost:5173
AUTH_SECRET_KEY=goal-development-secret-change-before-production
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=604800
AUTH_OAUTH_TTL_SECONDS=600
AUTH_LAST_SEEN_INTERVAL_SECONDS=300
GOOGLE_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# GOOGLE_OIDC_CLIENT_ID=
# GOOGLE_OIDC_CLIENT_SECRET=

VITE_API_BASE_URL=/api
