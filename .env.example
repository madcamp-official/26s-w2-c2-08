APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
# 자동 class 제목의 생성 시각 표시와 서버 시간대 기준입니다.
APP_TIMEZONE=Asia/Seoul

POSTGRES_HOST=127.0.0.1
POSTGRES_HOST_PORT=5432
POSTGRES_DB=tbd
POSTGRES_USER=tbd
POSTGRES_PASSWORD=tbd_dev

# Optional for development. APP_ENV=production requires an explicit URL that
# does not use the repository tbd/tbd_dev credentials.
# DATABASE_URL=postgresql+psycopg://tbd:tbd_dev@127.0.0.1:5432/tbd

STORAGE_ROOT=./data/uploads
# Decimal 100 MB. This must match the Material DB constraint and API contract.
MAX_UPLOAD_BYTES=100000000

# AI provider profile. `fake` is deterministic and remains the default for
# development and CI. A migration deletes old fake KnowledgeChunks and queues
# a full reindex; set `ollama` before starting that Knowledge worker when the
# resulting vectors must use the local embeddinggemma runtime.
AI_PROVIDER=fake
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=mistral-small3.2:24b
OLLAMA_EMBEDDING_MODEL=embeddinggemma
# PDF·Transcript 근거 검색과 KnowledgeChunk 색인에 쓰는 embedding 요청의 최대 시간입니다.
# EmbeddingGemma의 첫 로딩을 고려해 VM에서 너무 짧게 설정하지 않습니다.
KNOWLEDGE_EMBEDDING_TIMEOUT_SECONDS=60
# 개인 AI Chat·Summary의 단일 Ollama 요청 최대 시간입니다. 24B 모델 첫 요청은
# 로딩 시간이 길 수 있으므로, VM에서 너무 짧게 설정하지 않습니다.
PERSONAL_AI_PROVIDER_TIMEOUT_SECONDS=60

# STT는 기본적으로 비활성화되어 CI·일반 개발 환경에서 모델을 내려받지 않습니다.
# KCloud GPU VM에서 faster-whisper를 사용할 때만 STT_PROVIDER=faster_whisper로 설정합니다.
STT_PROVIDER=unavailable
STT_HQ_MODEL=large-v3
STT_LIVE_MODEL=large-v3-turbo
STT_DEVICE=cuda
STT_COMPUTE_TYPE=float16
STT_LANGUAGE=ko
STT_LIVE_WINDOW_MS=2000
STT_LIVE_FINALIZE_MS=6000
STT_LIVE_TIMEOUT_SECONDS=5

# Browser authentication. Production requires HTTPS origins, a unique secret,
# and AUTH_COOKIE_SECURE=true. Google credentials are required only when Google
# login is enabled.
FRONTEND_ORIGIN=http://localhost:5173
AUTH_ALLOWED_ORIGINS=http://localhost:5173
AUTH_SECRET_KEY=goal-development-secret-change-before-production
AUTH_COOKIE_SECURE=true
AUTH_SESSION_TTL_SECONDS=604800
AUTH_OAUTH_TTL_SECONDS=600
AUTH_LAST_SEEN_INTERVAL_SECONDS=300
GOOGLE_OIDC_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
# GOOGLE_OIDC_CLIENT_ID=
# GOOGLE_OIDC_CLIENT_SECRET=

# Base64-encoded 32-byte AES-256-GCM key for encrypted idempotency responses.
# Required when APP_ENV=production. Generate outside the repository, for example:
# openssl rand -base64 32
# IDEMPOTENCY_RESPONSE_ENCRYPTION_KEY=
# IDEMPOTENCY_RESPONSE_ENCRYPTION_KEY_VERSION=1

# Course 참여 코드 표시용 AES-256-GCM key와 조회용 HMAC key는 서로 달라야 한다.
# 둘 다 저장소 밖에서 생성하며 APP_ENV=production에서는 필수다.
# COURSE_JOIN_CODE_ENCRYPTION_KEY=
# COURSE_JOIN_CODE_ENCRYPTION_KEY_VERSION=1
# COURSE_JOIN_CODE_LOOKUP_KEY=
# COURSE_JOIN_CODE_LOOKUP_KEY_VERSION=1

# Vite는 같은 origin의 `/api` 요청을 FastAPI로 proxy한다. 기본값은 비워 둔다.
# 별도 API origin이 필요하면 origin만 지정한다. `/api` 경로를 덧붙이지 않는다.
# VITE_API_BASE_URL=https://api.example.com
